			"    }",
			"    void apply(int l, int r, const Action &d) {  // 区間[l,r)を作用素dを用いて更新する．O(logN).",
			"        assert(0 <= l and l <= r and r <= sz);",
			"        if(l == r) return;",
			"        l += n, r += n;",
			"        for(int i = depth; i >= 1; --i) {",
