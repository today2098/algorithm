			"// 二項係数（mod付き）．",
			"template <int mod>",
			"class Combination {",
			"    int sz;                                  // sz:=(要素数). ただし，sz<mod．",
			"    std::vector<long long> fact, inv, finv;  // fact[n]:=(nの階乗), inv[n]:=(nの逆元), finv[n]:=(nの逆元の階乗).",
