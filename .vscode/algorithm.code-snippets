			"// Binary Indexed Tree 2D.",
			"template <typename T>",
			"class BIT2D {",
			"    int h, w;                          // h:=(height), w:=(width).",
			"    std::vector<std::vector<T> > dat;  // 1-based index.",
			"",
			"    void build() {",
			"        for(int i = 1; i <= h; ++i)",
			"            for(int j = 1; j <= w; ++j) {",
